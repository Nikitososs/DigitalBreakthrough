# Домен и Let's Encrypt (для HTTPS через nginx)
DOMAIN=example.com
EMAIL=admin@example.com
# 1 — staging-сертификат для тестов, 0 — боевой
CERTBOT_STAGING=0

# Порты на хосте
HTTP_PORT=80
HTTPS_PORT=443
OLLAMA_PORT=11434

# LLM
OLLAMA_MODEL=gemma4:e2b

# ONNX: cuda | cpu (для GPU-сборки образа задайте ONNX_VARIANT=gpu)
ONNX_DEVICE=cuda
ONNX_VARIANT=gpu

# GPU (оставьте all для полного доступа)
NVIDIA_VISIBLE_DEVICES=all

# Чтение Excel: auto | calamine | openpyxl (calamine быстрее на больших .xlsx)
EXCEL_ENGINE=auto

# JWT и учётная запись администратора (создаётся при первом старте API)
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_MINUTES=480
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# PostgreSQL (docker compose поднимает контейнер postgres автоматически)
POSTGRES_USER=zeroproblems
POSTGRES_PASSWORD=zeroproblems
POSTGRES_DB=zeroproblems
POSTGRES_PORT=5432

# API: в Docker задаётся в docker-compose.yml; локально без Docker — SQLite:
# DATABASE_URL=sqlite:///./data/zeroproblems.db
# DATABASE_URL=postgresql+psycopg://zeroproblems:zeroproblems@localhost:5432/zeroproblems

# Геокодирование — только локальный Nominatim (Омская область, в docker-compose.yml)
NOMINATIM_URL=http://nominatim:8080
NOMINATIM_MIN_INTERVAL_SEC=0
NOMINATIM_CONCURRENCY=8
GEOCODE_WARMUP_BATCH=80
NOMINATIM_PORT=8088
